          "pluginVersion": "4.14.0",
          "queryType": "table",
          "rawSql": "SELECT time, service, max(val) as status FROM (\r\n    SELECT toDateTime(toUInt64(timestamp / 5) * 5) as time, service, 1 as val\r\n    FROM default.logs WHERE timestamp >= ($__from / 1000) GROUP BY time, service\r\n    UNION ALL\r\n    SELECT toDateTime(toUInt64(timestamp / 5) * 5) as time, 'generator' as service, 0 as val\r\n    FROM default.logs WHERE timestamp >= ($__from / 1000)\r\n    UNION ALL\r\n    SELECT toDateTime(toUInt64(timestamp / 5) * 5) as time, 'gwfi' as service, 0 as val\r\n    FROM default.logs WHERE timestamp >= ($__from / 1000)\r\n    UNION ALL\r\n    SELECT toDateTime(toUInt64(timestamp / 5) * 5) as time, 'adapter' as service, 0 as val\r\n    FROM default.logs WHERE timestamp >= ($__from / 1000)\r\n) GROUP BY time, service ORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "Статусы сервисов",
